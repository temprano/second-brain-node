# ── Second Brain Pipeline — Environment Config ──────────────────────────────
# Copy to .env and fill in your values. Never commit .env to git.

# ── Web Search Provider ──────────────────────────────────────────────────────
# Decoupled from LLM — any model (including Kimi) can now do research.
# Pick ONE provider and add its key. Others can be left blank.
#
# SERPER  — recommended — fastest, cheapest, Google results
#           Free: 2,500 queries, no credit card needed
#           Get key: serper.dev/api-key
#
# SERPAPI — multi-engine (Google, Bing, Yahoo, Baidu...)
#           Free: 250 searches/month
#           Get key: serpapi.com/manage-api-key
#
# BRAVE   — independent index, privacy-focused
#           Free: 2,000 queries/month
#           Get key: brave.com/search/api

SEARCH_PROVIDER=serper

SERPER_API_KEY=your-serper-api-key-here
SERPAPI_KEY=your-serpapi-key-here
BRAVE_SEARCH_API_KEY=your-brave-search-key-here


ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
GOOGLE_API_KEY=your-gemini-key-here

# NVIDIA NIM — free access to Kimi K2.5, Kimi K2 Instruct, Llama, Mistral + more
# Get your free key at: build.nvidia.com → sign in → API Keys (no payment needed)
NVIDIA_API_KEY=nvapi-your-key-here

# ── Model routing — assign models to pipeline roles ─────────────────────────
# Each role can use a different provider/model
# Format: "provider:model-name"
#
# RESEARCH_MODEL   — web search + source gathering (needs search capability)
# SYNTHESIS_MODEL  — condenses research into structured notes + flashcards
# REVIEW_MODEL     — optional quality check pass on generated cards
#
# Default (Anthropic only):
MODEL_RESEARCH=anthropic:claude-sonnet-4-6      # web search + reasoning
MODEL_SYNTHESIS=anthropic:claude-sonnet-4-6     # structured JSON output
MODEL_REVIEW=openai:gpt-4o-mini                 # fast + cheap review pass
#
# ── Kimi via NVIDIA NIM examples ─────────────────────────────────────────────
# Use Kimi K2 Instruct for synthesis — great at structured output + tool use:
# MODEL_SYNTHESIS=nvidia:moonshotai/kimi-k2-instruct
#
# Use Kimi K2.5 (multimodal) for synthesis when notes contain images:
# MODEL_SYNTHESIS=nvidia:moonshotai/kimi-k2.5
#
# Use Kimi K2 Thinking for the review pass — deep chain-of-thought reasoning:
# MODEL_REVIEW=nvidia:moonshotai/kimi-k2-thinking
#
# Short aliases also work (all route to NVIDIA NIM automatically):
# MODEL_SYNTHESIS=kimi:instruct
# MODEL_SYNTHESIS=kimi:vision
# MODEL_REVIEW=kimi:thinking
#
# ── Full Kimi pipeline (no Anthropic/OpenAI needed) ──────────────────────────
# Note: Kimi models don't have web search — research still needs Anthropic/OpenAI
# MODEL_RESEARCH=anthropic:claude-sonnet-4-6    # keep for web search
# MODEL_SYNTHESIS=kimi:instruct                 # Kimi handles synthesis
# MODEL_REVIEW=kimi:thinking                    # Kimi thinking for review

# ── Obsidian Local REST API ──────────────────────────────────────────────────
# Install plugin: Obsidian → Community Plugins → "Local REST API"
# Get key from: plugin settings → API Key
OBSIDIAN_API_KEY=your-obsidian-rest-api-key
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=27124
OBSIDIAN_VAULT_PATH=100-Learning/Research

# ── Anki (AnkiConnect) ───────────────────────────────────────────────────────
# Anki must be open with AnkiConnect installed (addon: 2055492159)
ANKI_HOST=http://localhost:8765
ANKI_DECK_PREFIX=Learning

# ── NotebookLM Integration ───────────────────────────────────────────────────
# Option A: notebooklm-py bridge (uses your personal Google account)
# Run: pip install notebooklm-py && notebooklm auth login
# Then set to "true" to enable
NOTEBOOKLM_ENABLED=false
NOTEBOOKLM_BRIDGE=notebooklm   # CLI command name after pip install

# Option B: Open Notebook (self-hosted NotebookLM alternative)
# Run: docker-compose up -d  (see open-notebook setup)
OPEN_NOTEBOOK_ENABLED=false
OPEN_NOTEBOOK_HOST=http://localhost:5000

# ── Pipeline behaviour ───────────────────────────────────────────────────────
# Number of Anki cards to generate per topic
CARDS_PER_TOPIC=8
# Auto-sync Anki to AnkiWeb after adding cards
AUTO_SYNC_ANKI=true
# Save a local markdown backup even if Obsidian write succeeds
LOCAL_BACKUP=false
LOCAL_BACKUP_PATH=./output_notes

# ── OpenClaw webhook integration ─────────────────────────────────────────────
# These let the pipeline POST completion notifications back to OpenClaw
# so you get a message on WhatsApp/Telegram/Discord when a job finishes.
#
# OPENCLAW_HOST: where your OpenClaw gateway is running
#   - If OpenClaw is on the SAME VPS: http://localhost:18789
#   - If OpenClaw is on your Windows PC: http://<tailscale-ip>:18789
#
# OPENCLAW_HOOKS_TOKEN: must match hooks.token in OpenClaw config.yaml
#
# OPENCLAW_AGENT_ID: which agent to notify (default: main)
# OPENCLAW_NOTIFY: set false to disable completion notifications

OPENCLAW_HOST=http://localhost:18789
OPENCLAW_HOOKS_TOKEN=your-openclaw-hooks-token-here
OPENCLAW_AGENT_ID=main
OPENCLAW_NOTIFY=true

# Obsidian attachments folder — PDFs uploaded via /upload are saved here
OBSIDIAN_ATTACHMENTS_FOLDER=_attachments
